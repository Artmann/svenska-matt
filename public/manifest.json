{
  "manifest_version": 3,
  "name": "Svenska Mått",
  "description": "Läser ingredienserna i ett recept och gör om dem till svenska mått och svenska ingrediensnamn.",
  "version": "0.1.0",
  "action": {
    "default_popup": "index.html",
    "default_title": "Svenska Mått"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "contextMenus"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
